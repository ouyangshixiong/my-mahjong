{
  "name": "mahjong-android-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Lightweight Android WebView Mahjong trainer with server-managed rules and splash ads.",
  "scripts": {
    "build:web": "sh scripts/build-web.sh",
    "test": "node --test tests/*.test.js",
    "test:server": "node --test tests/server.test.js",
    "server:start": "node server/index.js",
    "android:debug": "npm run build:web && ./gradlew assembleDebug",
    "android:release": "sh scripts/build-release.sh"
  },
  "devDependencies": {
    "esbuild": "0.25.6"
  }
}
